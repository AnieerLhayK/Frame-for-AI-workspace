{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workspace Agent Capability Lease",
  "type": "object",
  "required": [
    "lease_id",
    "agent",
    "issued_by",
    "capabilities",
    "path_scopes",
    "starts_at",
    "expires_at",
    "status",
    "isolation"
  ],
  "properties": {
    "lease_id": {
      "type": "string",
      "pattern": "^LEASE-[0-9]{8}-[0-9]{3}$"
    },
    "agent": {
      "type": "string",
      "minLength": 1
    },
    "issued_by": {
      "type": "string",
      "enum": ["user", "codex", "claude"]
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "record_write",
          "source_write",
          "structural_write",
          "platform_write"
        ]
      }
    },
    "path_scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "starts_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "enum": ["requested", "active", "expired", "revoked", "closed"]
    },
    "isolation": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {
          "enum": ["none", "branch", "worktree"]
        },
        "branch": {
          "type": "string"
        },
        "worktree_path": {
          "type": "string"
        }
      }
    }
  },
  "additionalProperties": false
}
