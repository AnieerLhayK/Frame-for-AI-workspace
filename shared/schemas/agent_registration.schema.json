{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workspace Agent Registration",
  "type": "object",
  "required": [
    "id",
    "display_name",
    "aliases",
    "identity_kind",
    "host",
    "status",
    "registration_type",
    "role",
    "trust_source",
    "capabilities",
    "path_scopes",
    "platforms",
    "skill_access",
    "storage",
    "session_store",
    "lifecycle"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "display_name": {"type": "string", "minLength": 1},
    "aliases": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "identity_kind": {
      "enum": ["agent", "agent_host", "tool_client", "unknown_candidate"]
    },
    "host": {
      "type": "object",
      "required": ["id", "kind"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "kind": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "status": {
      "enum": ["proposed", "testing", "active", "suspended", "retired"]
    },
    "registration_type": {
      "enum": ["permanent", "experimental", "temporary", "candidate"]
    },
    "role": {"type": "string", "minLength": 1},
    "trust_source": {"type": "string", "minLength": 1},
    "capabilities": {
      "type": "object",
      "required": ["inherit_role", "allow"],
      "properties": {
        "inherit_role": {"type": "boolean"},
        "allow": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": false
    },
    "path_scopes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "platforms": {"type": "array"},
    "skill_access": {"type": "object"},
    "storage": {"type": "object"},
    "session_store": {"type": "object"},
    "lifecycle": {
      "type": "object",
      "required": ["owner", "reviewed_at", "expires_at"],
      "properties": {
        "owner": {"type": ["string", "null"]},
        "reviewed_at": {"type": ["string", "null"], "format": "date-time"},
        "expires_at": {"type": ["string", "null"], "format": "date-time"}
      },
      "additionalProperties": false
    },
    "active_lease_refs": {
      "type": "array",
      "items": {"type": "string"}
    },
    "git_branch": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]*$"
    }
  },
  "additionalProperties": true
}
