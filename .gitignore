# Python and test caches
__pycache__/
*.pyc
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local scratch files and environments
tmp/
temp/
.env
*.log
*.tmp
*.bak
*.swp
~$*.docx

# OS and shell artifacts
.DS_Store
Thumbs.db
*.lnk

# Build and packaged outputs
dist/
*.zip

# Private corpora, backups, and external source drops
corpus/
backups/
archives/
archive*/
external-skills/

# Workspace report snapshots and generated report derivatives
reports/legacy_git_metadata/
**/reports/corpus_stats.md

# Standalone skills may keep additional runtime-output rules in their own
# .gitignore files so they remain publishable outside this workspace.

# Claude Code project-local state. Shared Claude instructions and settings may
# still be tracked explicitly through CLAUDE.md and .claude/settings.json.
.claude/*.local.json
.claude/*.local.md
.claude/routing_events.ndjson

# Manifest-managed project skill projections. Source lives under skills/ or packages/.
.claude/skills/

# Local MCP installs and runtime artifacts. Keep mcp/README.md and
# mcp/configs/*.json tracked as reproducible setup notes/templates.
mcp/servers/
mcp/downloads/
mcp/logs/

# Obsidian workspace/local config - machine-bound, highly volatile.
.obsidian/

# Public workspace staging - generated by scripts/publish_public.py.
publish-staging/
