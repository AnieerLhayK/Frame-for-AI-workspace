{
  "workspace": {
    "workspace_name": "governed-ai-workspace-template",
    "workspace_version": "1.3.0",
    "source_of_truth": "${WORKSPACE_ROOT}",
    "manifest_format": "json-compatible-yaml",
    "manifest_path": "workspace_manifest.yaml",
    "description": "Portable manifest for a governed AI workspace framework."
  },
  "platform_roots": {
    "codex": "${DATA_ROOT}/codex/skills",
    "claude": "${WORKSPACE_ROOT}/.claude/skills",
    "opencode": "${USER_HOME}/.config/opencode/skills",
    "hermes": "${DATA_ROOT}/hermes/skills"
  },
  "session_stores": {
    "claude": {
      "data_root": "${DATA_ROOT}/claude",
      "projects_path": "projects",
      "project_identity": "workspace-root"
    },
    "opencode": {
      "data_root": "${DATA_ROOT}/opencode/current-share",
      "database_path": "opencode.db",
      "project_identity": "git-worktree"
    }
  },
  "output_roots": {
    "workspace": "${DATA_ROOT}/out/workspace"
  },
  "external_roots": {
    "research": "${DATA_ROOT}/research",
    "raw_skills": "${DATA_ROOT}/research/skills",
    "adapted_skills": "${WORKSPACE_ROOT}/external-skills"
  },
  "shared": {
    "id": "shared",
    "source_path": "shared",
    "dependency_policy": "single-source",
    "projection_paths": {}
  },
  "packages": [],
  "skills": [],
  "projections": [],
  "protocols": [
    {
      "id": "workspace_policy",
      "path": "shared/workspace_policy.md",
      "required": true
    },
    {
      "id": "discovery_rules",
      "path": "shared/discovery_rules.md",
      "required": true
    },
    {
      "id": "failure_policy",
      "path": "shared/failure_policy.md",
      "required": true
    },
    {
      "id": "workspace_path_policy",
      "path": "shared/workspace_path_policy.md",
      "required": true
    },
    {
      "id": "reporting_policy",
      "path": "shared/reporting_policy.md",
      "required": true
    },
    {
      "id": "manifest_portability_policy",
      "path": "shared/manifest_portability_policy.md",
      "required": true
    },
    {
      "id": "session_continuity_policy",
      "path": "shared/session_continuity_policy.md",
      "required": true
    },
    {
      "id": "agent_governance_policy",
      "path": "shared/agent_governance_policy.md",
      "required": true
    },
    {
      "id": "delivery_output_policy",
      "path": "shared/delivery_output_policy.md",
      "required": true
    }
  ],
  "portability": {
    "bootstrap": {
      "enabled": true,
      "max_parent_depth": 5,
      "manifest_filename": "workspace_manifest.yaml"
    },
    "path_style": {
      "internal_paths": "workspace_relative",
      "platform_roots": "absolute_local",
      "projection_links": "absolute_local",
      "projection_targets": "workspace_relative"
    },
    "migration": {
      "dry_run_supported": true,
      "auto_move_allowed": false,
      "auto_relink_allowed": false
    }
  },
  "discovery": {
    "max_parent_depth": 5,
    "search_order": [
      "current_skill_directory",
      "parent_manifest_lookup",
      "workspace_shared_directory",
      "platform_shared_projection",
      "manifest_shared_root"
    ],
    "forbidden": [
      "whole_disk_search",
      "unbounded_parent_walk",
      "silent_fallback",
      "copying_shared_protocols"
    ]
  },
  "failure_policy": {
    "required_missing": "error_stop",
    "optional_missing": "warning_degraded_mode",
    "error_format": "standard_block"
  }
}
